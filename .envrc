use mise

# 預設 development，可用 APP_ENV=staging direnv reload 切換
APP_ENV="${APP_ENV:-development}"

_encrypted=".env.${APP_ENV}.encrypted"
if [ -f "$_encrypted" ]; then
  watch_file "$_encrypted"
  while IFS='=' read -r key value; do
    # 跳過空行和註解
    [[ -z "$key" || "$key" == \#* ]] && continue
    export "$key=$value"
  done < <(sops -d "$_encrypted")
else
  echo "⚠ $_encrypted not found, skipping secrets"
fi
